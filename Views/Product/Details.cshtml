@model ShopNet.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Product" asp-action="Index">Products</a>
            </li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Product Image -->
        <div class="col-md-6">
            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded shadow" />
        </div>

        <!-- Product Info -->
        <div class="col-md-6">
            <span class="badge bg-secondary mb-2">@Model.Category</span>
            <h1 class="mb-3">@Model.Name</h1>
            <p class="text-muted">@Model.Description</p>

            <hr />

            <div class="mb-3">
                <span class="display-6 fw-bold text-primary">
                    ₹@Model.Price.ToString("N0")
                </span>
            </div>

            <!-- Stock Status -->
            @if (Model.IsInStock)
            {
                <p class="text-success fw-semibold">
                    ✅ In Stock (@Model.Stock units available)
                </p>

                <div class="d-flex gap-3 mt-4">
                    <div class="input-group" style="width: 130px;">
                        <span class="input-group-text">Qty</span>
                        <input type="number" class="form-control" value="1" min="1" max="@Model.Stock" />
                    </div>
                    <button class="btn btn-primary btn-lg flex-grow-1">
                        🛒 Add to Cart
                    </button>
                </div>
                <button class="btn btn-outline-danger w-100 mt-2">
                    ♥ Add to Wishlist
                </button>
            }
            else
            {
                <p class="text-danger fw-semibold">❌ Out of Stock</p>
                <button class="btn btn-outline-secondary w-100 mt-3" disabled>
                    Notify Me When Available
                </button>
            }

            <hr />

            <!-- Back Link -->
            <a asp-controller="Product" asp-action="Index" class="btn btn-link ps-0">
                ← Back to Products
            </a>
        </div>
    </div>
</div>