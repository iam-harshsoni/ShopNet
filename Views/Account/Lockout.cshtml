@{
    ViewData["Title"] = "Account Locked";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-body p-5">
                    <h1 class="display-1">🔒</h1>
                    <h3 class="text-danger">Account Temporarily Locked</h3>
                    <p class="text-muted mt-3">
                        Too many failed login attempts. Your account has been locked
                        for security. Please try again in a few minutes.
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mt-3">
                        Return to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>