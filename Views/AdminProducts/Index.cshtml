@model IEnumerable<ShopNet.Models.Product>

@{
    ViewData["Title"] = "Manage Products";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📦 Manage Products</h2>
        <a asp-action="Create" class="btn btn-success">+ Add New Product</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>
                            <img src="@product.ImageUrl" width="60" height="40" style="object-fit:cover;" class="rounded" />
                        </td>
                        <td class="fw-semibold">@product.Name</td>
                        <td>
                            <span class="badge bg-secondary">@product.Category?.Name</span>
                        </td>
                        <td>₹@product.Price.ToString("N0")</td>
                        <td>@product.Stock</td>
                        <td>
                            @if (product.IsInStock)
                            {
                                <span class="badge bg-success">In Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Out of Stock</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@product.Id"
                               class="btn btn-sm btn-outline-primary me-1">Edit</a>

                            <form asp-action="Delete" asp-route-id="@product.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this product?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>