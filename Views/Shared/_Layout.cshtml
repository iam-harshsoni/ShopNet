@using Microsoft.AspNetCore.Identity
@inject SignInManager<ShopNet.Models.ApplicationUser> SignInManager
@inject UserManager<ShopNet.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ShopNest</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Head", required: false)
</head>

<body>

    <!-- ── NAVBAR ────────────────────────────────────────────── -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">

            <!-- Brand -->
            <a class="navbar-brand fw-bold fs-4"
               asp-controller="Home" asp-action="Index">
                🏪 ShopNest
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav"
                    aria-controls="navbarNav"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <!-- ── LEFT NAV ──────────────────────────────── -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home" asp-action="Index">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Product" asp-action="Index">
                            Products
                        </a>
                    </li>

                    <!-- Categories Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#"
                           role="button" data-bs-toggle="dropdown"
                           aria-expanded="false">
                            Categories
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-category="Electronics">
                                    🖥️ Electronics
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-category="Footwear">
                                    👟 Footwear
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-category="Fitness">
                                    🏋️ Fitness
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-category="Appliances">
                                    🏠 Appliances
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-category="Accessories">
                                    👜 Accessories
                                </a>
                            </li>
                        </ul>
                    </li>

                </ul>

                <!-- ── RIGHT NAV: Search + Cart + Auth ──────── -->
                <div class="d-flex align-items-center gap-3">

                    <!-- Search -->
                    <form asp-controller="Product"
                          asp-action="Index"
                          method="get"
                          class="d-flex">
                        <input type="text"
                               name="search"
                               placeholder="Search..."
                               class="form-control form-control-sm me-2"
                               style="width: 180px;" />
                        <button type="submit"
                                class="btn btn-outline-light btn-sm">
                            🔍
                        </button>
                    </form>

                    <!-- Cart ViewComponent -->
                    @await Component.InvokeAsync("CartSummary")

                    <!-- Auth Section -->
                    <ul class="navbar-nav mb-2 mb-lg-0">

                        @if (SignInManager.IsSignedIn(User))
                        {
                            var currentUser = await UserManager.GetUserAsync(User);

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white"
                                   href="#" role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    👤 @currentUser?.FirstName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Account"
                                           asp-action="Profile">
                                            👤 My Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="#">
                                            📦 My Orders
                                        </a>
                                    </li>

                                    @if (User.IsInRole("Admin") || User.IsInRole("StoreManager"))
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item text-danger fw-semibold"
                                               asp-controller="AdminProducts"
                                               asp-action="Index">
                                                🔧 Admin Panel
                                            </a>
                                        </li>
                                    }

                                    <li><hr class="dropdown-divider" /></li>

                                    <li>
                                        <form asp-controller="Account"
                                              asp-action="Logout"
                                              method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="dropdown-item text-danger">
                                                🚪 Sign Out
                                            </button>
                                        </form>
                                    </li>

                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Sign In
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-sm btn-outline-warning ms-1 px-3"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }

                    </ul>
                    <!-- End Auth Section -->

                </div>
                <!-- End Right Nav -->

            </div>
        </div>
    </nav>
    <!-- ── END NAVBAR ────────────────────────────────────────── -->

    <!-- ── MAIN CONTENT ──────────────────────────────────────── -->
    <main class="py-4">

        @* Success notification *@
        @if (TempData["Success"] != null)
        {
            <div class="container">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close"
                            data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @* Error notification *@
        @if (TempData["Error"] != null)
        {
            <div class="container">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close"
                            data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @RenderBody()

    </main>
    <!-- ── END MAIN ───────────────────────────────────────────── -->

    <!-- ── FOOTER ─────────────────────────────────────────────── -->
    <footer class="bg-dark text-white mt-5 py-4">
        <div class="container">
            <div class="row">

                <div class="col-md-4 mb-3">
                    <h5 class="fw-bold">🏪 ShopNest</h5>
                    <p class="text-muted small">
                        Your one-stop shop for everything you need.
                    </p>
                </div>

                <div class="col-md-4 mb-3">
                    <h6 class="fw-semibold">Quick Links</h6>
                    <ul class="list-unstyled small">
                        <li>
                            <a asp-controller="Home" asp-action="Index"
                               class="text-muted text-decoration-none">
                                Home
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Product" asp-action="Index"
                               class="text-muted text-decoration-none">
                                Products
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Account" asp-action="Login"
                               class="text-muted text-decoration-none">
                                Sign In
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="col-md-4 text-md-end">
                    <p class="text-muted small mb-1">
                        © @DateTime.Now.Year ShopNest.
                        All rights reserved.
                    </p>
                    <p class="text-muted small">
                        Built with ASP.NET Core MVC
                    </p>
                </div>

            </div>
        </div>
    </footer>
    <!-- ── END FOOTER ─────────────────────────────────────────── -->

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js">
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>