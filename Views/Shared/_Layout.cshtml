<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ShopNest</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Our custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* Any page can inject extra <head> content here *@
    @await RenderSectionAsync("Head", required: false)
</head>

<body>

    <!-- ── NAVBAR ─────────────────────────────────────── -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">

            <!-- Brand -->
            <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                🏪 ShopNest
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <!-- Left Nav Links -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            Products
                        </a>
                    </li>

                    <!-- Category Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            Categories
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" asp-controller="Product" asp-action="Index"
                                       asp-route-category="Electronics">
                                    Electronics
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Product" asp-action="Index"
                                       asp-route-category="Footwear">
                                    Footwear
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Product" asp-action="Index"
                                       asp-route-category="Fitness">
                                    Fitness
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>

                <!-- Right Nav — Search + Cart + Account -->
                <div class="d-flex align-items-center gap-3">

                    <!-- Inline Search -->
                    <form asp-controller="Product" asp-action="Index" method="get" class="d-flex">
                        <input type="text" name="search" placeholder="Search..."
                               class="form-control form-control-sm me-2" style="width: 180px;" />
                        <button type="submit" class="btn btn-outline-light btn-sm">
                            🔍
                        </button>
                    </form>

                    <a asp-controller="Cart" asp-action="Index"
                           class="btn btn-outline-warning btn-sm position-relative">
                        🛒 Cart
                        <span class="position-absolute top-0 start-100 translate-middle
                            badge rounded-pill bg-danger" id="cart-count">
                            0
                        </span>
                    </a>

                    <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">
                        Login
                    </a>

                </div>
            </div>
        </div>
    </nav>

    <main class="py-4">
        @if (TempData["Success"] != null)
        {
            <div class="container">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="bg-dark text-white mt-5 py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5 class="fw-bold">🏪 ShopNest</h5>
                    <p class="text-muted small">Your one-stop shop for everything.</p>
                </div>
                <div class="col-md-4">
                    <h6>Quick Links</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">Home</a>
                        </li>
                        <li><a asp-controller="Product" asp-action="Index"
                                   class="text-muted text-decoration-none">Products</a></li>
                        </ul>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <p class="text-muted small">© @DateTime.Now.Year ShopNest. All rights reserved.</p>
                    </div>
                </div>
            </div>
        </footer>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js">
        </script>

        @await RenderSectionAsync("Scripts", required: false)

    </body>

</html>